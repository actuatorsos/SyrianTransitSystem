# Supabase (free tier: https://supabase.com)
# For 500-vehicle scale: use Supavisor pooler URL instead of the default project URL.
# Enable Supavisor in Supabase dashboard: Settings → Database → Connection Pooling.
# Pooler URL format: https://aws-0-<region>.pooler.supabase.com
# Default URL (max ~150 vehicles): https://your-project.supabase.co
SUPABASE_URL=https://aws-0-eu-central-1.pooler.supabase.com
SUPABASE_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# JWT Auth
JWT_SECRET=change-me-to-a-random-64-char-string

# CORS — comma-separated list of allowed origins. Wildcards (*) are rejected.
# Production: production domain only. Dev: add localhost origins as needed.
# VERCEL_ENV=production automatically strips localhost entries.
ALLOWED_ORIGINS=https://syrian-transit-system.vercel.app,https://syrian-transit-system-*.vercel.app,http://localhost:3000,http://localhost:8000

# Optional: Traccar webhook secret
TRACCAR_WEBHOOK_SECRET=optional-shared-secret

# Optional: Environment
ENVIRONMENT=production

# Optional: Resend email notifications (https://resend.com)
# Create a free account and add/verify a sending domain.
# Alert emails go to operators; welcome emails go to new users.
RESEND_API_KEY=re_...your-api-key
RESEND_FROM_EMAIL=alerts@yourdomain.com
# Comma-separated list of admin email addresses to receive critical alert emails
ALERT_EMAIL_RECIPIENTS=ops@yourdomain.com
