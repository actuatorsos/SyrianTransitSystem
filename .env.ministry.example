# ============================================================
# DamascusTransit — Ministry Self-Hosted Configuration
# Copy this file to .env and fill in all required values.
# NEVER commit the filled-in .env to version control.
# ============================================================

# ── Supabase (Required) ──────────────────────────────────────
# Obtain from your Supabase project: Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=eyJ...           # anon/public key
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (keep secret)
SUPABASE_ANON_KEY=eyJ...      # same as SUPABASE_KEY for most setups

# ── Security (Required) ──────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── CORS (Required) ──────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# Set to your Ministry domain(s). No trailing slash.
ALLOWED_ORIGINS=https://transit.mot.gov.sy,https://admin.transit.mot.gov.sy

# ── Error Tracking (Optional) ────────────────────────────────
# Sign up for a free Sentry account at sentry.io and create a Python project.
# Copy the DSN from Settings → Client Keys. Leave blank to disable.
SENTRY_DSN=

# ── Traccar GPS Integration (Optional) ───────────────────────
# Only needed if using Traccar hardware GPS devices.
# Generate with: openssl rand -hex 32
TRACCAR_WEBHOOK_SECRET=

# ── Redis Override (Optional) ─────────────────────────────────
# Leave blank to use the bundled Redis container.
# Set to an Upstash REST URL+token to use managed Redis instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
