<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ===== App identity ===== -->
    <key>CFBundleDisplayName</key>
    <string>نقل دمشق</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- ===== UI settings ===== -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>
    <key>UIStatusBarHidden</key>
    <false/>
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleLightContent</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- RTL support — matches Arabic lang in PWA manifest -->
    <key>NSPrincipalClass</key>
    <string>UIApplication</string>

    <!-- ===== Supported orientations ===== -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- ===== Required permissions ===== -->

    <!-- Location — foreground (passenger + driver) -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>يحتاج نقل دمشق إلى موقعك لعرض أقرب المحطات والحافلات القادمة.</string>

    <!-- Location — background (driver app only) -->
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>يتطلب تطبيق السائق تتبع الموقع في الخلفية لمشاركة الموقع الفعلي للحافلة مع الركاب طوال الرحلة.</string>
    <key>NSLocationAlwaysUsageDescription</key>
    <string>يحتاج تطبيق السائق إلى الوصول إلى موقعك في جميع الأوقات لتتبع مسار الرحلة.</string>

    <!-- Camera (driver incident photos) -->
    <key>NSCameraUsageDescription</key>
    <string>يحتاج نقل دمشق إلى الكاميرا لالتقاط صور الحوادث وإرسال تقارير ميدانية لمركز التحكم.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>يحتاج التطبيق إلى حفظ صور الحوادث في مكتبة الصور.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>يحتاج التطبيق إلى الوصول إلى الصور لإرفاقها في تقارير الحوادث.</string>

    <!-- Face ID (biometric login for drivers) -->
    <key>NSFaceIDUsageDescription</key>
    <string>استخدم Face ID لتسجيل الدخول بأمان وسرعة في تطبيق السائق.</string>

    <!-- ===== Background modes ===== -->
    <key>UIBackgroundModes</key>
    <array>
        <!-- APNs push notifications -->
        <string>remote-notification</string>
        <!-- Background location for driver tracking -->
        <string>location</string>
        <!-- Background fetch (optional, for route updates) -->
        <string>fetch</string>
    </array>

    <!-- ===== URL schemes ===== -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>sy.gov.damascus.transit</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>transit</string>
            </array>
        </dict>
    </array>

    <!-- ===== App Transport Security ===== -->
    <!-- Production: all traffic must use HTTPS -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <!-- Allow localhost for development only -->
        <key>NSExceptionDomains</key>
        <dict>
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- ===== Capacitor / WKWebView settings ===== -->
    <key>WKAppBoundDomains</key>
    <array>
        <string>transit.damascus.gov.sy</string>
    </array>

</dict>
</plist>
